<!-- app/views/gossips/index.html.erb -->
<div class="jumbotron bg-light p-5 mb-4 rounded">
  <h1 class="display-4">Bienvenue sur The Gossip Project!</h1>
  <p class="lead">Le site où tous les potins sont partagés</p>
  <% if logged_in? %>
    <%= link_to "Créer un nouveau potin", new_gossip_path, class: "btn btn-primary" %>
  <% else %>
    <p>Connectez-vous pour créer des potins et liker</p>
    <%= link_to "Se connecter", login_path, class: "btn btn-primary" %>
    <%= link_to "S'inscrire", signup_path, class: "btn btn-outline-primary ms-2" %>
  <% end %>
</div>

<div class="row">
  <% @gossips.each do |gossip| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><%= gossip.title %></h5>
          
          <% if logged_in? %>
            <% like = current_user.likes.find_by(likable: gossip) %>
            <% if like %>
              <%= button_to like_path(like), method: :delete, class: "btn btn-sm btn-danger" do %>
                <i class="fas fa-heart"></i> <%= gossip.likes.count %>
              <% end %>
            <% else %>
              <%= button_to gossip_likes_path(gossip), method: :post, class: "btn btn-sm btn-outline-danger" do %>
                <i class="far fa-heart"></i> <%= gossip.likes.count %>
              <% end %>
            <% end %>
          <% else %>
            <span class="btn btn-sm btn-outline-secondary disabled">
              <i class="far fa-heart"></i> <%= gossip.likes.count %>
            </span>
          <% end %>
        </div>
        
        <div class="card-body">
          <p class="card-text"><%= truncate(gossip.content, length: 100) %></p>
        </div>
        
        <div class="card-footer bg-white">
          <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">Par <%= gossip.user.first_name %></small>
            <div>
              <%= link_to "Voir plus", gossip_path(gossip), class: "btn btn-sm btn-primary" %>
              <% if logged_in? && current_user == gossip.user %>
                <%= link_to edit_gossip_path(gossip), class: "btn btn-sm btn-outline-secondary ms-1" do %>
                  <i class="fas fa-edit"></i>
                <% end %>
                <%= button_to gossip_path(gossip), method: :delete, class: "btn btn-sm btn-outline-danger ms-1", form: { style: "display: inline" }, data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce potin?" } do %>
                  <i class="fas fa-trash"></i>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>