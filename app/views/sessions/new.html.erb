<!-- app/views/sessions/new.html.erb -->
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h3 class="mb-0">Connexion</h3>
      </div>
      <div class="card-body">
        <%= form_with(scope: :session, url: login_path) do |f| %>
          <div class="mb-3">
            <%= f.label :email, "Adresse email", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Mot de passe", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>

          <div class="d-grid">
            <%= f.submit "Se connecter", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
      <div class="card-footer text-center">
        <p class="mb-0">Pas encore de compte? <%= link_to "S'inscrire", signup_path %></p>
      </div>
    </div>
  </div>
</div>